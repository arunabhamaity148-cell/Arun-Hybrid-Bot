# ─────────────────────────────────────────────
#  ARUNABHA HYBRID BOT v1.0  —  Environment File
# ─────────────────────────────────────────────

# === BINANCE (primary data source) ===
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

# === COINDCX (price reference) ===
COINDCX_API_KEY=your_coindcx_api_key_here
COINDCX_SECRET=your_coindcx_secret_here

# === DELTA EXCHANGE (READ-ONLY price feed — NO trading) ===
DELTA_API_KEY=your_delta_api_key_here
DELTA_SECRET=your_delta_secret_here

# === COINGECKO (free tier — no key needed, but set if you have pro) ===
COINGECKO_API_KEY=

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === BOT SETTINGS ===
SCAN_INTERVAL_SECONDS=300
COINGECKO_REFRESH_SECONDS=3600
MIN_24H_CHANGE_PCT=7.0
MIN_VOLUME_MULTIPLIER=3.0
MIN_MARKET_CAP_USD=50000000
VOLUME_ANOMALY_MULTIPLIER=5.0
MIN_RR_RATIO=2.5
MAX_DYNAMIC_PAIRS=13

# === RAILWAY / FASTAPI HEALTH ===
PORT=8080
LOG_LEVEL=INFO